{
  "name": "@repo/data",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "pnpm format"
    ]
  },
  "scripts": {
    "dev": "pkgroll --watch",
    "prebuild": "rimraf ./dist",
    "build": "pkgroll",
    "format": "prettier --write **/* ",
    "pretest": "tf run db:test",
    "test": "tf test",
    "db:dev": "tf run db:dev",
    "db:prod": "tf run db:prod",
    "db:generate": "tf run db:generate",
    "db:migrate": "tf run db:migrate",
    "db:pull": "tf run db:pull",
    "db:dev:setup": "tf run db:dev:setup",
    "db:dev:push": "tf run db:dev:push",
    "db:dev:seed": "tf run db:dev:seed",
    "db:dev:studio": "tf run db:dev:studio",
    "db:test:setup": "tf run db:test:setup",
    "db:test:push": "tf run db:test:push",
    "db:test:seed": "tf run db:test:seed",
    "db:test:studio": "tf run db:test:studio",
    "db:prod:setup": "tf run db:prod:setup",
    "db:prod:push": "tf run db:prod:push",
    "db:prod:seed": "tf run db:prod:seed",
    "db:prod:studio": "tf run db:prod:studio"
  },
  "dependencies": {
    "@repo/env": "workspace:*",
    "drizzle-orm": "^0.39.3",
    "mysql2": "^3.19.1",
    "taskforge-cli": "^1.0.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^22.19.15",
    "drizzle-kit": "^0.30.6",
    "lint-staged": "^16.2.7",
    "pkgroll": "^2.27.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.4"
  },
  "exports": {
    "./querries/*": {
      "require": {
        "types": "./dist/querries/*.d.cts",
        "default": "./dist/querries/*.cjs"
      },
      "import": {
        "types": "./dist/querries/*.d.mts",
        "default": "./dist/querries/*.mjs"
      }
    },
    ".": {
      "require": {
        "types": "./dist/exports/index.d.cts",
        "default": "./dist/exports/index.cjs"
      },
      "import": {
        "types": "./dist/exports/index.d.mts",
        "default": "./dist/exports/index.mjs"
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0"
}
