{
  "name": "@repo/utils",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "pnpm format"
    ]
  },
  "scripts": {
    "prebuild": "rimraf ./dist",
    "dev": "pkgroll --watch",
    "build": "pkgroll",
    "format": "prettier --write **/* ",
    "test": "vitest"
  },
  "dependencies": {
    "@repo/data": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "lint-staged": "^16.2.7",
    "pkgroll": "^2.27.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "exports": {
    "./utility": {
      "require": {
        "types": "./dist/utility/index.d.cts",
        "default": "./dist/utility/index.cjs"
      },
      "import": {
        "types": "./dist/utility/index.d.mts",
        "default": "./dist/utility/index.mjs"
      }
    },
    "./zod-schema/*": {
      "require": {
        "types": "./dist/zod-schema/*.d.cts",
        "default": "./dist/zod-schema/*.cjs"
      },
      "import": {
        "types": "./dist/zod-schema/*.d.mts",
        "default": "./dist/zod-schema/*.mjs"
      }
    },
    "./const/*": {
      "require": {
        "types": "./dist/const/*.d.cts",
        "default": "./dist/const/*.cjs"
      },
      "import": {
        "types": "./dist/const/*.d.mts",
        "default": "./dist/const/*.mjs"
      }
    },
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.27.0"
}
